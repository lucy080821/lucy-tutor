generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String?
  phone        String?
  avatar       String?
  role         String   @default("STUDENT") // "STUDENT" or "TEACHER"
  targetScore  Float    @default(7.0)
  currentLevel String   @default("Lost Roots")
  streakCount  Int      @default(0)
  lastActive   DateTime @default(now())
  totalXP      Int      @default(0)
  
  examResults  ExamResult[]
  mistakeBank  MistakeBank[]
  notebooks    MistakeNotebook[]
  
  classroomsOwned   Classroom[] @relation("TeacherClassrooms")
  classroomJoinedId String?
  classroomJoined   Classroom?  @relation("StudentClassrooms", fields: [classroomJoinedId], references: [id])
  uploadedExams     Exam[]      @relation("TeacherExams")
  assignedExams     Exam[]      @relation("AssignedExams")
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Question {
  id            String   @id @default(uuid())
  heading       String?
  content       String
  type          String
  difficulty    String
  options       String   // stored as JSON string
  correctOption String
  explanation   String?
  
  mistakeBank   MistakeBank[]
  exams         ExamQuestion[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Exam {
  id            String   @id @default(uuid())
  title         String
  duration      Int      // in minutes
  totalQuestions Int
  
  examType      String   @default("REGULAR") // "REGULAR" or "PLACEMENT"
  grade         Int?     // e.g., 6, 7, 8, 9, 10, 11, 12
  publishTime   DateTime?
  deadline      DateTime?
  notes         String?
  maxAttempts   Int      @default(1)
  
  classroomId   String?
  classroom     Classroom? @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  
  uploadedById  String?
  uploadedBy    User?      @relation("TeacherExams", fields: [uploadedById], references: [id], onDelete: SetNull)
  
  assignedStudents User[]  @relation("AssignedExams")
  
  questions     ExamQuestion[]
  results       ExamResult[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ExamQuestion {
  examId      String
  questionId  String
  order       Int
  
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
}

model ExamResult {
  id             String   @id @default(uuid())
  userId         String
  examId         String
  selectedAnswers String   // stored as JSON string
  score          Float
  timeSpent      Int      // in seconds
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime @default(now())
}

model MistakeBank {
  userId           String
  questionId       String
  wrongAnswerCount Int      @default(1)
  nextReviewDate   DateTime @default(now())
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question         Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  @@id([userId, questionId])
}

model MistakeNotebook {
  id            String   @id @default(uuid())
  userId        String
  topic         String   // e.g., "Câu điều kiện (Conditional Sentences)"
  theoryContent String   // Comprehensive explanation generated by AI
  mistakeCount  Int      @default(1)
  correctCount  Int      @default(0)
  status        String   @default("NEEDS_WORK") // "NEEDS_WORK" or "RESOLVED"
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([userId, topic])
}

model Classroom {
  id          String   @id @default(uuid())
  name        String
  joinCode    String   @unique
  teacherId   String
  
  teacher     User     @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  students    User[]   @relation("StudentClassrooms")
  exams       Exam[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
